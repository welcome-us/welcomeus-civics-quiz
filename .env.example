# Anthropic API key used by the server-side answer grader (app/api/grade).
# Copy this file to `.env.local` and fill in a real key.
# Without it, the app falls back to the deterministic browser matcher.
ANTHROPIC_API_KEY=
SF_ENDPOINT=

# Google Tag Manager container ID (looks like "GTM-XXXXXXX").
# Leave blank to disable GTM entirely (no script is injected).
NEXT_PUBLIC_GTM_ID=